# Runtime environment: development, testing, or production.
APP_ENV=production

# Required in production. Generate a random, long value, for example:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# SQLite database location.
DATABASE_PATH=data/accounting.db

# Set true in production behind HTTPS.
SESSION_COOKIE_SECURE=true

# Flask-Limiter storage. Use Redis in production when available, for example:
# RATELIMIT_STORAGE_URI=redis://127.0.0.1:6379/0
RATELIMIT_STORAGE_URI=memory://

# Logging.
LOG_DIR=logs
LOG_LEVEL=INFO

# SQLite backup settings.
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=14

# Gunicorn settings.
GUNICORN_BIND=127.0.0.1:8000
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=30
