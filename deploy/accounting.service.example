[Unit]
Description=Accounting System
After=network.target

[Service]
Type=simple
User=your-user
Group=your-user
WorkingDirectory=/opt/accounting-system
EnvironmentFile=/opt/accounting-system/.env
ExecStart=/opt/accounting-system/venv/bin/gunicorn -c gunicorn.conf.py server:app
Restart=always
RestartSec=5
StartLimitIntervalSec=60
StartLimitBurst=5

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/opt/accounting-system/data /opt/accounting-system/logs /opt/accounting-system/backups

[Install]
WantedBy=multi-user.target
